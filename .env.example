# ElevenLabs API key — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Anthropic API key — https://console.anthropic.com — used for title translation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vimeo — https://developer.vimeo.com/apps → generate token with upload + edit scopes
VIMEO_ACCESS_TOKEN=your_vimeo_access_token_here
# Optional: Vimeo folder/showcase ID (find it in the URL: vimeo.com/manage/folders/{id})
VIMEO_FOLDER_ID=

# Circle community — Developers → Tokens → Admin V2
CIRCLE_API_TOKEN=your_circle_api_token_here

# Slack app — https://api.slack.com/apps
# Required bot scopes: channels:history, chat:write, groups:history
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# YouTube — run `python3 scripts/youtube_auth.py` once to generate these
# Google Cloud → YouTube Data API v3 → OAuth 2.0 credentials (Desktop app)
YOUTUBE_CLIENT_ID=your_google_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_google_oauth_client_secret
YOUTUBE_REFRESH_TOKEN=your_refresh_token_from_auth_script
# Optional: add every video to a specific playlist
# Find the ID in the URL: youtube.com/playlist?list=PLxxxxxxxx
YOUTUBE_PLAYLIST_ID=

# HeyGen credentials (kept for future phases)
HEYGEN_API_KEY=your_heygen_api_key_here
HEYGEN_VOICE_ID=your_heygen_voice_id_here

# Output directory for downloaded videos (default: downloads)
DOWNLOAD_DIR=downloads
